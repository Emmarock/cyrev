<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1773518456637-1" author="apata">
        <createTable tableName="governance_requests">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_governance_requests"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="version" type="BIGINT"/>
            <column name="deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)"/>
            <column name="operation_type" type="VARCHAR(255)"/>
            <column name="target_id" type="VARCHAR(255)"/>
            <column name="principal_id" type="VARCHAR(255)"/>
            <column name="additional_id" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="approval_status" type="VARCHAR(255)"/>
            <column name="approved_by" type="VARCHAR(255)"/>
            <column name="approved_at" type="DATETIME"/>
            <column name="is_approval_required" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="VARCHAR(4000)"/>
        </createTable>
    </changeSet>
    <changeSet id="1773518456637-2" author="apata">
        <createTable tableName="saas_tenant">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_saas_tenant"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="entra_tenant_id" type="VARCHAR(255)"/>
            <column name="display_name" type="VARCHAR(255)"/>
            <column name="consent_granted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="consented_at" type="DATETIME"/>
            <column name="plan" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="organization_id" type="UUID"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1773518456637-3" author="apata">
        <createTable tableName="tenant_audit_logs">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_tenant_audit_logs"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)"/>
            <column name="action" type="VARCHAR(255)"/>
            <column name="actor" type="VARCHAR(255)"/>
            <column name="reference_id" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="details" type="VARCHAR(4000)"/>
            <column name="timestamp" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1773518456637-4" author="apata">
        <createTable tableName="user_invites">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_invites"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="version" type="BIGINT"/>
            <column name="deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="inviter_id" type="UUID"/>
            <column name="role" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="invite_token" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1773518456637-5" author="apata">
        <addColumn tableName="users">
            <column name="auth_provider" type="VARCHAR(255)"/>
            <column name="provider_user_id" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>
    <changeSet id="1773518456637-7" author="apata">
        <addUniqueConstraint columnNames="entra_tenant_id" constraintName="uc_saas_tenant_entra_tenant"
                             tableName="saas_tenant"/>
    </changeSet>
    <changeSet id="1773518456637-8" author="apata">
        <addUniqueConstraint columnNames="organization_id" constraintName="uc_saas_tenant_organization"
                             tableName="saas_tenant"/>
    </changeSet>
    <changeSet id="1773518456637-9" author="apata">
        <addUniqueConstraint columnNames="invite_token" constraintName="uc_user_invites_invitetoken"
                             tableName="user_invites"/>
    </changeSet>
    <changeSet id="1773518456637-10" author="apata">
        <addForeignKeyConstraint baseColumnNames="organization_id" baseTableName="saas_tenant"
                                 constraintName="FK_SAAS_TENANT_ON_ORGANIZATION" referencedColumnNames="id"
                                 referencedTableName="organizations"/>
    </changeSet>
    <changeSet id="1773518456637-11" author="apata">
        <addForeignKeyConstraint baseColumnNames="inviter_id" baseTableName="user_invites"
                                 constraintName="FK_USER_INVITES_ON_INVITER" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>
    <changeSet id="1773518456637-12" author="apata">
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="group_members"
                                 constraintName="fk_gromem_on_user" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>
    <changeSet id="1773518456637-13" author="apata">
        <addForeignKeyConstraint baseColumnNames="organization_id" baseTableName="organization_owners"
                                 constraintName="fk_orgown_on_organization" referencedColumnNames="id"
                                 referencedTableName="organizations"/>
    </changeSet>
    <changeSet id="1773518456637-14" author="apata">
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="organization_owners"
                                 constraintName="fk_orgown_on_user" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>