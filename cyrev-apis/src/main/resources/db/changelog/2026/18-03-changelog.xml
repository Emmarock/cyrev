<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1773875563502-6" author="apata">
        <dropForeignKeyConstraint baseTableName="addresses" constraintName="fk_addresses_on_organization"/>
    </changeSet>
    <changeSet id="1773875563502-7" author="apata">
        <dropForeignKeyConstraint baseTableName="saas_tenant" constraintName="fk_saas_tenant_on_organization"/>
    </changeSet>
    <changeSet id="1773875563502-8" author="apata">
        <dropForeignKeyConstraint baseTableName="users" constraintName="fk_users_on_organization"/>
    </changeSet>
    <changeSet id="1773875563502-1" author="apata">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="addresses" columnName="tenant_id"/>
            </not>
        </preConditions>
        <addColumn tableName="addresses">
            <column name="tenant_id" type="UUID"/>
        </addColumn>
    </changeSet>
    <changeSet id="1773875563502-2" author="apata">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="tenant_id"/>
            </not>
        </preConditions>
        <addColumn tableName="users">
            <column name="tenant_id" type="UUID"/>
        </addColumn>
    </changeSet>
    <changeSet id="1773875563502-3" author="apata">
        <addUniqueConstraint columnNames="tenant_id" constraintName="uc_addresses_tenant" tableName="addresses"/>
    </changeSet>
    <changeSet id="1773875563502-4" author="apata">
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="addresses"
                                 constraintName="FK_ADDRESSES_ON_TENANT" referencedColumnNames="id"
                                 referencedTableName="saas_tenant"/>
    </changeSet>
    <changeSet id="1773875563502-5" author="apata">
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="users" constraintName="FK_USERS_ON_TENANT"
                                 referencedColumnNames="id" referencedTableName="saas_tenant"/>
    </changeSet>
    <changeSet id="1773875563502-11" author="apata">
        <dropColumn columnName="organization_id" tableName="addresses"/>
    </changeSet>
    <changeSet id="1773875563502-12" author="apata">
        <dropColumn columnName="organization_id" tableName="saas_tenant"/>
    </changeSet>
    <changeSet id="1773875563502-13" author="apata">
        <dropColumn columnName="organization_id" tableName="users"/>
    </changeSet>

</databaseChangeLog>